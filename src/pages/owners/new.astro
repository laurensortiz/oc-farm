---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../lib/db/index';
import { owners } from '../../lib/db/schema';

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();

    const name  = form.get('name')?.toString().trim() ?? '';
    const phone = form.get('phone')?.toString().trim() || null;
    const email = form.get('email')?.toString().trim() || null;
    const notes = form.get('notes')?.toString().trim() || null;

    if (!name) throw new Error('El nombre es obligatorio');

    const [newOwner] = await db
      .insert(owners)
      .values({ name, phone, email, notes })
      .returning({ id: owners.id });

    return Astro.redirect(`/owners/${newOwner.id}`);
  } catch (e) {
    error = e instanceof Error ? e.message : 'Error al guardar';
  }
}
---

<Layout title="Nuevo dueño">
  <div class="space-y-5">

    <div class="flex items-center gap-2">
      <a href="/owners" class="btn btn-ghost btn-sm btn-square">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-xl font-bold">Registrar dueño</h1>
    </div>

    {error && <div class="alert alert-error text-sm"><span>{error}</span></div>}

    <form method="POST" class="space-y-6">

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-5 space-y-4">
          <h2 class="font-semibold text-base border-b border-base-300 pb-2">Datos de contacto</h2>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Nombre *</label>
            <input type="text" name="name" class="input input-bordered w-full" required placeholder="Nombre completo" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Teléfono</label>
            <input type="tel" name="phone" class="input input-bordered w-full" placeholder="+57 300 000 0000" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Correo electrónico</label>
            <input type="email" name="email" class="input input-bordered w-full" placeholder="nombre@correo.com" />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Notas</label>
            <textarea name="notes" class="textarea textarea-bordered w-full" rows="3" placeholder="Información adicional..."></textarea>
          </div>
        </div>
      </div>

      <button type="submit" class="btn btn-soft btn-primary w-full text-base">
        Guardar dueño
      </button>

    </form>
  </div>
</Layout>
