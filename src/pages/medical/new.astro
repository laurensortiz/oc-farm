---
import Layout from '../../layouts/Layout.astro';
import { db } from '../../lib/db/index';
import { animals, medicalRecords } from '../../lib/db/schema';
import { medicalRecordTypeLabel, speciesIcon } from '../../lib/labels';
import { eq } from 'drizzle-orm';

let error = '';

// Pre-selección por query param
const preselectedAnimalId = Astro.url.searchParams.get('animalId') ?? '';

if (Astro.request.method === 'POST') {
  try {
    const form = await Astro.request.formData();

    const animalIdRaw  = form.get('animal_id')?.toString() || null;
    const animalId     = animalIdRaw ? parseInt(animalIdRaw) : null;
    const recordType   = form.get('record_type')?.toString() as any;
    const date         = form.get('date')?.toString() || null;
    const medication   = form.get('medication')?.toString().trim() || null;
    const dose         = form.get('dose')?.toString().trim() || null;
    const veterinarian = form.get('veterinarian')?.toString().trim() || null;
    const nextCheckDate = form.get('next_check_date')?.toString() || null;
    const notes        = form.get('notes')?.toString().trim() || null;

    if (!animalId)   throw new Error('Debe seleccionar un animal');
    if (!recordType) throw new Error('El tipo de registro es obligatorio');
    if (!date)       throw new Error('La fecha es obligatoria');

    await db.insert(medicalRecords).values({
      animalId,
      recordType,
      date,
      medication,
      dose,
      veterinarian,
      nextCheckDate: nextCheckDate || null,
      notes,
    });

    return Astro.redirect(`/animals/${animalId}`);
  } catch (e) {
    error = e instanceof Error ? e.message : 'Error al guardar';
  }
}

const animalList = await db
  .select({ id: animals.id, code: animals.code, name: animals.name, species: animals.species })
  .from(animals)
  .orderBy(animals.code);

const today = new Date().toISOString().split('T')[0];
---

<Layout title="Nuevo control médico">
  <div class="space-y-5">

    <div class="flex items-center gap-2">
      <a href="/animals" class="btn btn-ghost btn-sm btn-square">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </a>
      <h1 class="text-xl font-bold">Control médico</h1>
    </div>

    {error && <div class="alert alert-error text-sm"><span>{error}</span></div>}

    <form method="POST" class="space-y-4">

      <div class="card bg-base-100 shadow-sm">
        <div class="card-body p-5 space-y-4">

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Animal *</label>
            <select name="animal_id" class="select select-bordered w-full" required>
              <option value="">Seleccionar animal...</option>
              {animalList.map((a) => (
                <option value={a.id} selected={preselectedAnimalId === String(a.id)}>
                  {speciesIcon[a.species]} {a.name ? `${a.name} (${a.code})` : a.code}
                </option>
              ))}
            </select>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Tipo *</label>
              <select name="record_type" class="select select-bordered w-full" required>
                <option value="">Seleccionar...</option>
                {Object.entries(medicalRecordTypeLabel).map(([val, label]) => (
                  <option value={val}>{label}</option>
                ))}
              </select>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Fecha *</label>
              <input type="date" name="date" class="input input-bordered w-full" value={today} required />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Medicamento</label>
              <input type="text" name="medication" class="input input-bordered w-full" placeholder="Ivermectina" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Dosis</label>
              <input type="text" name="dose" class="input input-bordered w-full" placeholder="5 ml" />
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Veterinario</label>
              <input type="text" name="veterinarian" class="input input-bordered w-full" placeholder="Dr. García" />
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-sm font-medium">Próximo control</label>
              <input type="date" name="next_check_date" class="input input-bordered w-full" />
            </div>
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-sm font-medium">Observaciones</label>
            <textarea name="notes" class="textarea textarea-bordered w-full" rows="2" placeholder="Notas adicionales..."></textarea>
          </div>

        </div>
      </div>

      <button type="submit" class="btn btn-soft btn-primary w-full text-base">
        Guardar registro
      </button>

    </form>
  </div>
</Layout>
